<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DragonEye</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="layout-fixed sidebar-expand-lg sidebar-mini" data-bs-theme="dark">
<div class="app-wrapper">
    <aside class="app-sidebar bg-primary shadow"><div class="sidebar-brand"><a asp-controller="Home" asp-action="Index" class="brand-link"><span class="brand-text fw-light">DragonEye</span></a></div><div class="sidebar-wrapper"><nav class="mt-2"><ul class="nav sidebar-menu flex-column"><li class="nav-item"><a asp-controller="Home" asp-action="Index" class="nav-link">Dashboard</a></li>@if (User.HasClaim("permission", "Hardware.View")){<li class="nav-item"><a asp-controller="Assets" asp-action="Index" class="nav-link">Hardware</a></li>}@if (User.HasClaim("permission", "Audit.View")){<li class="nav-item"><a asp-controller="AuditLogs" asp-action="Index" class="nav-link">Audit Logs</a></li>}</ul></nav></div></aside>
    <main class="app-main"><div class="app-content-header"><div class="container-fluid">@await Html.PartialAsync("_Breadcrumb")</div></div><div class="app-content"><div class="container-fluid">@RenderBody()</div></div></main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/js/adminlte.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

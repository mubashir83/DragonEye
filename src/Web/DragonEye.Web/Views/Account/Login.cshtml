@{
    Layout = null;
}
<!DOCTYPE html><html><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>Login - DragonEye</title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" /></head><body class="bg-light"><div class="container py-5"><div class="row justify-content-center"><div class="col-md-4"><div class="card"><div class="card-header"><h4 class="mb-0">Sign In</h4></div><div class="card-body">@if (ViewData["Error"] is string error){<div class="alert alert-danger">@error</div>}<form method="post"><div class="mb-3"><label class="form-label">Email</label><input name="Email" class="form-control" required /></div><div class="mb-3"><label class="form-label">Password</label><input type="password" name="Password" class="form-control" required /></div><button class="btn btn-primary w-100">Login</button></form></div></div></div></div></div></body></html>
